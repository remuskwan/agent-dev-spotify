{
  "name": "agent-dev-spotify",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/cli.ts",
    "serve": "tsx src/service/server.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.evals.json",
    "test": "vitest run --config evals/vitest.config.ts",
    "test:watch": "vitest --config evals/vitest.config.ts",
    "eval:live": "EVAL_MODE=live vitest run --config evals/vitest.config.ts --reporter=verbose",
    "eval:report": "tsx evals/tools/runReport.ts",
    "eval:report:live": "tsx evals/tools/runReport.ts --live",
    "eval:triage": "tsx evals/tools/triage.ts && tsx evals/tools/proposeFixes.ts",
    "eval:loop": "npm run eval:report && npm run eval:triage",
    "eval:verify": "tsx evals/tools/verify.ts",
    "eval:expand": "tsx evals/tools/expandGoldenSet.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "openai": "^4.77.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  }
}
